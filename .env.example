NODE_ENV=development

# Public URLs used by the browser.
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Internal service URLs.
GRAPHQL_URL=http://localhost:4000/graphql
TRIP_SERVICE_URL=http://localhost:4010
BOOKING_SERVICE_URL=http://localhost:4020
AI_SERVICE_URL=http://localhost:4100
ANALYTICS_SERVICE_URL=http://localhost:4050
SEAT_GRPC_URL=localhost:50051

# Infrastructure. The project runs with in-memory fallbacks if these are absent.
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672
KAFKA_BROKERS=localhost:9092

# AI SDK. Leave empty to use the deterministic rule-based assistant.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
